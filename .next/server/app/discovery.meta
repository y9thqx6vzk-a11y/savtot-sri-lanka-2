{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/discovery/layout,_N_T_/discovery/page,_N_T_/discovery"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/discovery/__PAGE__",
    "/discovery",
    "/_index",
    "/_head"
  ]
}